# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/fiatdex

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=your-super-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Injective
INJECTIVE_NETWORK=testnet
INJECTIVE_GRPC_ENDPOINT=https://testnet.sentry.exchange.grpc-web.injective.network
INJECTIVE_LCD_ENDPOINT=https://testnet.sentry.lcd.injective.network

# Onramp
TRANSAK_API_KEY=your_transak_key
TRANSAK_SECRET_KEY=your_transak_secret
TRANSAK_ENVIRONMENT=STAGING

KADO_API_KEY=your_kado_key

# Push Notifications
EXPO_PUSH_TOKEN_BASE=https://exp.host/--/api/v2/push/send

# General
ENVIRONMENT=development
CORS_ORIGINS=["*"]
